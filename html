    <script>
        // ==================== GLOBAL STATE ====================
        let chart, candleSeries, histogramSeries;
        let currentSymbol = 'BTCUSDT';
        let currentInterval = '15m';
        let candles = [];
        let currentPrice = 0;
        let apiConfig = null;
        let globalMode = 'demo'; // 'demo' or 'live'
        let tradingMode = 'demo';
        
        // Balances
        let demoBalance = 10000;
        let liveBalance = 0; // Fetched from API
        
        // Bots
        const bots = {
            1: { active: false, mode: 'demo', position: null, entry: 0, amount: 0, sl: 0, tp: 0, pnl: 0, side: null },
            2: { active: false, mode: 'demo', position: null, entry: 0, amount: 0, sl: 0, tp: 0, pnl: 0, side: null },
            3: { active: false, mode: 'demo', position: null, entry: 0, amount: 0, sl: 0, tp: 0, pnl: 0, side: null }
        };
        
        let positions = [];
        let orderHistory = [];

        // ==================== INIT ====================
        document.addEventListener('DOMContentLoaded', () => {
            initChart();
            loadApiConfig();
            setupEventListeners();
            loadData();
            updateBalanceDisplay();
        });

        function initChart() {
            const container = document.getElementById('chart-container');
            chart = LightweightCharts.createChart(container, {
                width: container.clientWidth,
                height: container.clientHeight,
                layout: {
                    background: { type: 'solid', color: '#ffffff' },
                    textColor: '#131722',
                },
                grid: {
                    vertLines: { color: '#e0e3eb' },
                    horzLines: { color: '#e0e3eb' },
                },
                crosshair: { mode: LightweightCharts.CrosshairMode.Normal },
                rightPriceScale: { borderColor: '#e0e3eb' },
                timeScale: { borderColor: '#e0e3eb', timeVisible: true },
            });

            candleSeries = chart.addCandlestickSeries({
                upColor: '#22ab94', downColor: '#f7525f',
                borderDownColor: '#f7525f', borderUpColor: '#22ab94',
                wickDownColor: '#f7525f', wickUpColor: '#22ab94',
            });

            histogramSeries = chart.addHistogramSeries({
                color: '#26a69a', priceFormat: { type: 'volume' },
                priceScaleId: '', scaleMargins: { top: 0.85, bottom: 0 },
            });

            window.addEventListener('resize', () => {
                chart.applyOptions({ width: container.clientWidth, height: container.clientHeight });
            });
        }

        // ==================== DATA LOADING ====================
        async function loadData() {
            document.getElementById('chartLoading').style.display = 'flex';
            try {
                const response = await fetch(`https://api.binance.com/api/v3/klines?symbol=${currentSymbol}&interval=${currentInterval}&limit=500`);
                const data = await response.json();
                candles = data.map(d => ({
                    time: d[0] / 1000, open: parseFloat(d[1]), high: parseFloat(d[2]),
                    low: parseFloat(d[3]), close: parseFloat(d[4]), volume: parseFloat(d[5])
                }));
                
                candleSeries.setData(candles.map(c => ({ time: c.time, open: c.open, high: c.high, low: c.low, close: c.close })));
                histogramSeries.setData(candles.map(c => ({ time: c.time, value: c.volume, color: c.close >= c.open ? '#22ab94' : '#f7525f' })));
                
                currentPrice = candles[candles.length - 1].close;
                updatePriceDisplay(candles[candles.length - 1]);
                document.getElementById('chartLoading').style.display = 'none';
                chart.timeScale().fitContent();
                
                connectWebSocket();
            } catch (error) {
                generateSimulatedData();
            }
        }

        function generateSimulatedData() {
            // Generate mock data
            let price = 45000;
            const now = Date.now();
            candles = [];
            for (let i = 300; i >= 0; i--) {
                const time = (now - (i * 900000)) / 1000;
                const change = (Math.random() - 0.5) * price * 0.002;
                const open = price;
                const close = price + change;
                candles.push({ time, open, high: Math.max(open, close) + 50, low: Math.min(open, close) - 50, close, volume: Math.random() * 1000 });
                price = close;
            }
            candleSeries.setData(candles.map(c => ({ time: c.time, open: c.open, high: c.high, low: c.low, close: c.close })));
            currentPrice = candles[candles.length - 1].close;
            updatePriceDisplay(candles[candles.length - 1]);
            document.getElementById('chartLoading').style.display = 'none';
            simulateLiveUpdates();
        }

        function connectWebSocket() {
            const ws = new WebSocket(`wss://stream.binance.com:9443/ws/${currentSymbol.toLowerCase()}@kline_${currentInterval}`);
            ws.onmessage = (event) => {
                const msg = JSON.parse(event.data);
                if (msg.k) {
                    const k = msg.k;
                    const candle = { time: k.t / 1000, open: parseFloat(k.o), high: parseFloat(k.h), low: parseFloat(k.l), close: parseFloat(k.c) };
                    updateLiveCandle(candle);
                }
            };
        }

        function simulateLiveUpdates() {
            setInterval(() => {
                const last = candles[candles.length - 1];
                const change = (Math.random() - 0.5) * last.close * 0.001;
                updateLiveCandle({ ...last, close: last.close + change, high: Math.max(last.high, last.close + change), low: Math.min(last.low, last.close + change) });
            }, 2000);
        }

        function updateLiveCandle(candle) {
            candleSeries.update({ time: candle.time, open: candle.open, high: candle.high, low: candle.low, close: candle.close });
            currentPrice = candle.close;
            updatePriceDisplay(candle);
            updatePositionsPnL();
            checkBots(candle);
            updateManualPreview();
        }

        function updatePriceDisplay(candle) {
            document.getElementById('currentPrice').textContent = '$' + candle.close.toFixed(2);
            const change = candle.close - candle.open;
            const pct = (change / candle.open) * 100;
            document.getElementById('priceChange').textContent = (change >= 0 ? '+' : '') + change.toFixed(2);
            document.getElementById('priceChange').className = change >= 0 ? 'text-up' : 'text-down';
            document.getElementById('priceChangePercent').textContent = '(' + (pct >= 0 ? '+' : '') + pct.toFixed(2) + '%)';
            document.getElementById('priceChangePercent').className = pct >= 0 ? 'text-up' : 'text-down';
        }

        // ==================== MODE SWITCHING ====================
        function setGlobalMode(mode) {
            globalMode = mode;
            document.getElementById('globalModeIndicator').className = mode === 'live' ? 'mode-indicator live' : 'mode-indicator';
            document.getElementById('btnGlobalDemo').className = mode === 'demo' ? 'mode-btn active' : 'mode-btn';
            document.getElementById('btnGlobalLive').className = mode === 'live' ? 'mode-btn active' : 'mode-btn';
        }

        function setTradingMode(mode) {
            if (mode === 'live' && !apiConfig) {
                alert('Please configure API settings first!');
                openApiModal();
                return;
            }
            tradingMode = mode;
            document.getElementById('tradingModeIndicator').className = mode === 'live' ? 'mode-indicator live' : 'mode-indicator';
            document.getElementById('btnTradingDemo').className = mode === 'demo' ? 'mode-btn active' : 'mode-btn';
            document.getElementById('btnTradingLive').className = mode === 'live' ? 'mode-btn active' : 'mode-btn';
            document.getElementById('tradingLiveWarning').style.display = mode === 'live' ? 'block' : 'none';
            document.getElementById('liveBalanceSource').style.display = mode === 'live' ? 'block' : 'none';
            updateBalanceDisplay();
        }

        function setBotMode(botId, mode) {
            if (mode === 'live' && !apiConfig) {
                alert('Please configure API settings first!');
                openApiModal();
                return;
            }
            bots[botId].mode = mode;
            document.getElementById(`bot${botId}ModeIndicator`).className = mode === 'live' ? 'mode-indicator live' : 'mode-indicator';
            document.getElementById(`bot${botId}-btn-demo`).className = mode === 'demo' ? 'mode-btn active' : 'mode-btn';
            document.getElementById(`bot${botId}-btn-live`).className = mode === 'live' ? 'mode-btn active' : 'mode-btn';
            document.getElementById(`bot${botId}-live-badge`).style.display = mode === 'live' ? 'inline-flex' : 'none';
            document.getElementById(`bot${botId}-card`).className = mode === 'live' ? 'bot-card live-mode' : 'bot-card';
        }

        // ==================== TRADING PANEL TOGGLE ====================
        function toggleTradingPanel() {
            const content = document.getElementById('tradingPanelContent');
            const icon = document.getElementById('tradingPanelIcon');
            content.classList.toggle('collapsed');
            icon.style.transform = content.classList.contains('collapsed') ? 'rotate(-90deg)' : 'rotate(0deg)';
        }

        // ==================== MANUAL TRADING ====================
        function updateManualPreview() {
            const amount = parseFloat(document.getElementById('manualAmount').value) || 0;
            const sl = parseFloat(document.getElementById('manualSL').value) || 0;
            const tp = parseFloat(document.getElementById('manualTP').value) || 0;
            
            if (amount > 0) {
                document.getElementById('manualPnlPreview').style.display = 'block';
                document.getElementById('manualPreviewEntry').textContent = '$' + currentPrice.toFixed(2);
                
                const profit = amount * (tp / 100);
                const loss = amount * (sl / 100);
                
                document.getElementById('manualPreviewProfit').textContent = '+$' + profit.toFixed(2);
                document.getElementById('manualPreviewLoss').textContent = '-$' + loss.toFixed(2);
            } else {
                document.getElementById('manualPnlPreview').style.display = 'none';
            }
        }

        document.getElementById('manualAmount').addEventListener('input', updateManualPreview);
        document.getElementById('manualSL').addEventListener('input', updateManualPreview);
        document.getElementById('manualTP').addEventListener('input', updateManualPreview);

        async function placeManualOrder(side) {
            const amount = parseFloat(document.getElementById('manualAmount').value);
            const sl = parseFloat(document.getElementById('manualSL').value) || 0;
            const tp = parseFloat(document.getElementById('manualTP').value) || 0;
            
            if (!amount || amount <= 0) {
                alert('Enter valid amount'); return;
            }
            
            const balance = tradingMode === 'demo' ? demoBalance : liveBalance;
            if (amount > balance) {
                alert('Insufficient balance'); return;
            }
            
            const position = {
                id: Date.now(), time: new Date().toLocaleTimeString(), symbol: currentSymbol,
                side: side.toUpperCase(), entry: currentPrice, amount: amount,
                quantity: amount / currentPrice, sl: sl, tp: tp,
                current: currentPrice, pnl: 0, mode: tradingMode, status: 'OPEN'
            };
            
            positions.push(position);
            
            if (tradingMode === 'demo') {
                demoBalance -= amount;
            } else {
                liveBalance -= amount;
                // Execute real order via API
                await executeLiveOrder(side, amount, currentPrice);
            }
            
            updateBalanceDisplay();
            updatePositionsTable();
            document.getElementById('manualAmount').value = '';
            updateManualPreview();
        }

        async function executeLiveOrder(side, amount, price) {
            // Real API execution
            console.log(`LIVE ORDER: ${side} ${amount} USDT at ${price}`);
            // Implementation would call exchange API here
        }

        // ==================== BOT FUNCTIONS ====================
        function toggleBot(id) {
            const bot = bots[id];
            const btn = document.getElementById(`btn-bot${id}`);
            
            if (!bot.active) {
                const amount = parseFloat(document.getElementById(`bot${id}-amount`).value);
                if (!amount || amount <= 0) { alert('Enter amount'); return; }
                
                const balance = bot.mode === 'demo' ? demoBalance : liveBalance;
                if (amount > balance) { alert('Insufficient balance'); return; }
                
                bot.active = true;
                bot.amount = amount;
                bot.sl = parseFloat(document.getElementById(`bot${id}-sl`).value) || 2;
                bot.tp = parseFloat(document.getElementById(`bot${id}-tp`).value) || 5;
                
                btn.textContent = 'STOP BOT';
                btn.style.background = '#f7525f';
                btn.style.color = 'white';
                document.getElementById(`bot${id}-status`).style.background = '#22ab94';
                document.getElementById(`bot${id}-card`).classList.add('active');
                
                if (bot.mode === 'demo') demoBalance -= amount;
                else liveBalance -= amount;
                updateBalanceDisplay();
            } else {
                bot.active = false;
                if (bot.position) closeBotPosition(id);
                btn.textContent = 'START BOT';
                btn.style.background = '#f0f3fa';
                btn.style.color = '#131722';
                document.getElementById(`bot${id}-status`).style.background = '#d1d4dc';
                document.getElementById(`bot${id}-card`).classList.remove('active');
            }
        }

        function checkBots(candle) {
            Object.keys(bots).forEach(id => {
                const bot = bots[id];
                if (!bot.active) return;
                
                let signal = null;
                
                // Bot 1: Golden Cross
                if (id == 1) {
                    const ma20 = calculateMA(candles.slice(-30), 20);
                    const ma50 = calculateMA(candles.slice(-60), 50);
                    if (ma20.length >= 2 && ma50.length >= 2) {
                        if (ma20[ma20.length-2].value <= ma50[ma50.length-2].value && ma20[ma20.length-1].value > ma50[ma50.length-1].value) signal = 'buy';
                        else if (ma20[ma20.length-2].value >= ma50[ma50.length-2].value && ma20[ma20.length-1].value < ma50[ma50.length-1].value) signal = 'sell';
                    }
                }
                
                // Bot 2: RSI
                if (id == 2) {
                    // Simplified RSI logic
                    const changes = candles.slice(-15).map((c, i, arr) => i > 0 ? c.close - arr[i-1].close : 0);
                    const avgGain = changes.filter(c => c > 0).reduce((a, b) => a + b, 0) / 14;
                    const avgLoss = Math.abs(changes.filter(c => c < 0).reduce((a, b) => a + b, 0)) / 14;
                    const rsi = 100 - (100 / (1 + avgGain / avgLoss));
                    if (rsi < 30) signal = 'buy';
                    else if (rsi > 70) signal = 'sell';
                }
                
                // Bot 3: Breakout
                if (id == 3) {
                    const highs = candles.slice(-21, -1).map(d => d.high);
                    const lows = candles.slice(-21, -1).map(d => d.low);
                    if (candle.close > Math.max(...highs)) signal = 'buy';
                    else if (candle.close < Math.min(...lows)) signal = 'sell';
                }
                
                if (signal === 'buy' && !bot.position) openBotPosition(id, candle.close);
                else if (signal === 'sell' && bot.position) closeBotPosition(id);
                
                if (bot.position) updateBotPnL(id, candle.close);
            });
        }

        function openBotPosition(id, price) {
            const bot = bots[id];
            bot.position = true;
            bot.entry = price;
            bot.side = 'BUY';
            
            if (bot.mode === 'live') {
                executeLiveOrder('buy', bot.amount, price);
            }
        }

        function closeBotPosition(id) {
            const bot = bots[id];
            const pnl = ((currentPrice - bot.entry) / bot.entry) * 100;
            
            if (bot.mode === 'demo') demoBalance += bot.amount + (bot.amount * pnl / 100);
            else {
                liveBalance += bot.amount + (bot.amount * pnl / 100);
                executeLiveOrder('sell', bot.amount, currentPrice);
            }
            
            bot.position = false;
            bot.pnl = 0;
            updateBalanceDisplay();
        }

        function updateBotPnL(id, price) {
            const bot = bots[id];
            bot.pnl = ((price - bot.entry) / bot.entry) * 100;
            
            // Check SL/TP
            if (bot.pnl <= -bot.sl) closeBotPosition(id);
            else if (bot.pnl >= bot.tp) closeBotPosition(id);
            
            document.getElementById(`bot${id}-pnl`).textContent = `PnL: ${bot.pnl >= 0 ? '+' : ''}${bot.pnl.toFixed(2)}%`;
            document.getElementById(`bot${id}-pnl`).className = `mono ${bot.pnl >= 0 ? 'pnl-positive' : 'pnl-negative'}`;
        }

        function calculateMA(data, period) {
            const result = [];
            for (let i = period - 1; i < data.length; i++) {
                let sum = 0;
                for (let j = 0; j < period; j++) sum += data[i - j].close;
                result.push({ value: sum / period });
            }
            return result;
        }

        // ==================== POSITIONS & BALANCE ====================
        function updatePositionsPnL() {
            positions.forEach(pos => {
                if (pos.status !== 'OPEN') return;
                pos.current = currentPrice;
                const priceDiff = pos.side === 'BUY' ? currentPrice - pos.entry : pos.entry - currentPrice;
                pos.pnl = priceDiff * pos.quantity;
            });
            updatePositionsTable();
        }

        function closePosition(id) {
            const idx = positions.findIndex(p => p.id === id);
            if (idx === -1) return;
            const pos = positions[idx];
            pos.status = 'CLOSED';
            
            if (pos.mode === 'demo') demoBalance += pos.amount + pos.pnl;
            else liveBalance += pos.amount + pos.pnl;
            
            positions.splice(idx, 1);
            updateBalanceDisplay();
            updatePositionsTable();
        }

        function updatePositionsTable() {
            const tbody = document.getElementById('ordersTable');
            if (positions.length === 0) {
                tbody.innerHTML = '<tr><td colspan="8" style="padding: 40px; text-align: center; color: #787b86;">No active positions</td></tr>';
                return;
            }
            
            tbody.innerHTML = positions.map(pos => `
                <tr style="border-bottom: 1px solid #f0f3fa;">
                    <td style="padding: 10px; font-size: 11px; color: #787b86;">${pos.time}</td>
                    <td style="padding: 10px; font-weight: 600;">${pos.symbol}</td>
                    <td style="padding: 10px;"><span style="color: ${pos.side === 'BUY' ? '#22ab94' : '#f7525f'}; font-weight: 700;">${pos.side}</span></td>
                    <td style="padding: 10px; font-family: monospace;">$${pos.entry.toFixed(2)}</td>
                    <td style="padding: 10px; font-family: monospace;">$${pos.current.toFixed(2)}</td>
                    <td style="padding: 10px; color: ${pos.pnl >= 0 ? '#22ab94' : '#f7525f'}; font-weight: 700; font-family: monospace;">${pos.pnl >= 0 ? '+' : ''}$${pos.pnl.toFixed(2)}</td>
                    <td style="padding: 10px;"><span class="badge ${pos.mode === 'live' ? 'badge-success' : 'badge-info'}">${pos.mode.toUpperCase()}</span></td>
                    <td style="padding: 10px;"><button onclick="closePosition(${pos.id})" style="padding: 4px 8px; background: #f7525f; color: white; border: none; border-radius: 4px; font-size: 11px; cursor: pointer;">Close</button></td>
                </tr>
            `).join('');
        }

        function updateBalanceDisplay() {
            const balance = tradingMode === 'demo' ? demoBalance : liveBalance;
            document.getElementById('tradingBalance').textContent = '$' + balance.toFixed(2);
        }

        // ==================== API ====================
        function openApiModal() { document.getElementById('apiModal').style.display = 'flex'; }
        function closeApiModal() { document.getElementById('apiModal').style.display = 'none'; }
        
        function saveApiSettings() {
            const exchange = document.getElementById('apiExchange').value;
            const key = document.getElementById('apiKey').value;
            const secret = document.getElementById('apiSecret').value;
            
            if (!key || !secret) { alert('Enter API credentials'); return; }
            
            apiConfig = { exchange, key, secret };
            localStorage.setItem('trading_api', JSON.stringify(apiConfig));
            
            // Simulate fetching live balance
            liveBalance = 25000 + Math.random() * 10000;
            closeApiModal();
            alert('API Connected! You can now trade with real funds.');
        }

        function loadApiConfig() {
            const saved = localStorage.getItem('trading_api');
            if (saved) {
                apiConfig = JSON.parse(saved);
                document.getElementById('apiKey').value = apiConfig.key;
                document.getElementById('apiExchange').value = apiConfig.exchange;
                liveBalance = 25000; // Simulated
            }
        }

        function setupEventListeners() {
            document.getElementById('symbolSelect').addEventListener('change', (e) => {
                currentSymbol = e.target.value; loadData();
            });
            
            document.querySelectorAll('.tf-btn').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    document.querySelectorAll('.tf-btn').forEach(b => b.classList.remove('active'));
                    e.target.classList.add('active');
                    currentInterval = e.target.dataset.tf;
                    loadData();
                });
            });
        }

        function switchTab(tab) {
            ['positions', 'history'].forEach(t => {
                const btn = document.getElementById(`tab-${t}`);
                btn.style.color = t === tab ? '#2962FF' : '#787b86';
                btn.style.borderBottom = t === tab ? '2px solid #2962FF' : 'none';
            });
        }
    </script>
</body>
</html>
